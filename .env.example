# Usado pelo docker-compose.yml (raiz do repo). Copie para .env e ajuste antes
# de rodar docker compose up --build. Nao commitar .env (ja esta no .gitignore).
# Nao confundir com backend/.env, usado para rodar o Django fora do Docker.

# Preencha no .env local. Nao use valores reais neste arquivo de exemplo.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

POSTGRES_DB=nexo
POSTGRES_USER=nexo
POSTGRES_PASSWORD=

# Porta exposta do container backend no host
WEB_PORT=8000

# URL da API embutida no build do React (mesma origem do backend nesse compose)
VITE_API_URL=/api/v1
